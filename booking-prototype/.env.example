# Copy to .env and fill with your test keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_... # optional for local quick tests
PORT=4000
ADMIN_USER=admin
ADMIN_PASS=change_this_password

# Twilio (optional). If set, server will send real SMS.
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890
EMPLOYEE_PHONE=+15551234567
DEPOSIT_ENABLED=false
